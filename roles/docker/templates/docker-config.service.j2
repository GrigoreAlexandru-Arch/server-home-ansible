[Unit]
Description=Docker Compose service for home server configuration
Requires=docker.service {{ mount_unit_name }}
After=docker.service {{ mount_unit_name }}

[Service]
# Run tests/commands only once but consider the service active afterwards
Type=oneshot
RemainAfterExit=yes

# User/Group to run the service as
User={{ ansible_user }}
Group=docker

# Path to the directory containing docker-compose.yaml
WorkingDirectory={{ docker_config_path }}

# Increase timeouts for large pulls
TimeoutStartSec=0
TimeoutStopSec=120

# Use Docker Compose V2
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down

[Install]
WantedBy=multi-user.target

